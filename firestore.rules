rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()         { return request.auth != null; }
    function uid()            { return request.auth.uid; }
    function isOwner(ownerId) { return isAuth() && uid() == ownerId; }

    // ── GIGS ───────────────────────────────────────────
    match /gigs/{gigId} {
      allow read: if true;

      allow create: if isAuth()
        && request.resource.data.posterId == uid()
        && request.resource.data.keys().hasAll(['title','category','status','createdAt'])
        && request.resource.data.status == 'open';

      allow update: if isAuth() && (
        isOwner(resource.data.posterId)
        || (
          resource.data.status == "open"
          && request.resource.data.status == "taken"
          && request.resource.data.workerId == uid()
          && request.resource.data.posterId == resource.data.posterId
        )
        || (
          resource.data.status == "taken"
          && resource.data.workerId == uid()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["workerLat","workerLng","workerLocUpdatedAt"])
        )
        || (
          resource.data.status == "taken"
          && resource.data.workerId == uid()
          && request.resource.data.completionRequested == true
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["completionOTP","completionOTPExpiry",
                         "completionRequested","completionRequestedAt"])
        )
        || (
          resource.data.status == "taken"
          && resource.data.workerId == uid()
          && request.resource.data.status == "completed"
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["status","completedAt","workerEarnings","platformFee",
                         "completionOTP","completionOTPExpiry",
                         "completionRequested","completionRequestedAt"])
        )
        || (
          resource.data.status == "taken"
          && resource.data.workerId == uid()
          && request.resource.data.status == "cancelled"
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["status","cancelledBy","cancelReason","cancelledAt"])
        )
        || (
          resource.data.workerId == uid()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["reviewedByWorker"])
        )
        || (
          resource.data.posterId == uid()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["reviewedByPoster","posterDebited"])
        )
      );

      allow delete: if isOwner(resource.data.posterId);
    }

    // ── CONVERSATIONS ───────────────────────────────────
    match /conversations/{convId} {
      allow read:   if isAuth() && uid() in resource.data.participants;
      allow create: if isAuth();
      allow update: if isAuth() && uid() in resource.data.participants;
      allow delete: if false;

      match /messages/{msgId} {
        allow read:   if isAuth();
        allow create: if isAuth();
        allow update, delete: if false;
      }
    }

    // ── USERS ───────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isAuth() && uid() == userId;
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ── NOTIFICATIONS ───────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isAuth();
    }

    // ── WALLET ────────────────────────────────────────────
    match /wallets/{userId} {
      allow read, write: if isOwner(userId);

      match /transactions/{txnId} {
        allow read:           if isOwner(userId);
        allow create:         if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ── TRANSACTIONS ──────────────────────────────────────
    match /transactions/{txnId} {
      allow read: if isAuth() && (
        resource.data.userId     == uid()
        || resource.data.senderId   == uid()
        || resource.data.receiverId == uid()
      );
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── REVIEWS ───────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isOwner(resource.data.authorId);
    }

    // ── PUBLIC REVIEWS ───────────────────────────────────
    match /publicReviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAuth() && resource.data.reviewerUid == uid();
    }
  }
}
